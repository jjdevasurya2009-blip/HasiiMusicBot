# ==============================================================================
# sample.env - Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to git - it contains sensitive credentials!
# 
# How to get these values:
# - API_ID & API_HASH: https://my.telegram.org/apps
# - BOT_TOKEN: Create bot with @BotFather on Telegram
# - LOGGER_ID: Create a private group, add bot, get chat ID
# - MONGO_DB_URI: MongoDB connection string (use MongoDB Atlas for free)
# - OWNER_ID: Your Telegram user ID (get from @userinfobot)
# - STRING_SESSION: Generate from @StringFatherBot (Pyrogram session)
# - COOKIE_URL: Optional - URL to YouTube cookies file for age-restricted videos
# ==============================================================================

API_ID=
API_HASH=
BOT_TOKEN=
SESSION_STRING=
OWNER_ID=
MONGO_URI=
COOKIE_URL=


# Optional: Additional assistant sessions for handling multiple groups

# STRING_SESSION2=
# STRING_SESSION3=
# STRING_SESSION4=
# STRING_SESSION5=

# ==============================================================================
# FEATURE FLAGS (Optional)
# ==============================================================================

# AUTO_END: Automatically end stream when queue finishes (True/False)
# AUTO_END=False

# AUTO_LEAVE: Assistants auto-leave inactive groups every 30 min (True/False)
# AUTO_LEAVE=False

# THUMB_GEN: Generate custom thumbnails for now playing (True/False)
# THUMB_GEN=True

# VIDEO_PLAY: Enable /vplay commands for streaming video in VC (True/False)
# VIDEO_PLAY=True

# VIDEO_MAX_HEIGHT: Max resolution (in pixels) for /vplay downloads (e.g. 720, 1080)
# VIDEO_MAX_HEIGHT=1080

# ==============================================================================
# MODERATION (Optional)
# ==============================================================================

# EXCLUDED_USERNAMES: Space-separated list of usernames to exclude from admin mentions
# EXCLUDED_USERNAMES=User1 User2 User3
